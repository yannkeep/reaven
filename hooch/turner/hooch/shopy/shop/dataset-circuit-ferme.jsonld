    {
      "@type": "DefinedTerm",
      "name": "Particratie",
      "description": "Système politique où les partis politiques concentrent le pouvoir décisionnel au détriment des institutions parlementaires et des citoyens. Terme forgé par Marcel Grégoire en 1965. En Belgique, se manifeste par une discipline de vote à 99,73%, un kern sans base légale concentrant les décisions, et un financement public représentant ~80% des revenus des partis.",
      "inDefinedTermSet": {"@type": "DefinedTermSet", "name": "Lexique politique belge", "publisher": {"@type": "Organization", "name": "ouaisfieu"}}
    },
    {
      "@type": "DefinedTerm",
      "name": "Circuit fermé de la démocratie belge",
      "description": "Concept ouaisfieu décrivant le mécanisme systémique en 6 étapes où le citoyen produit de la légitimité sans pouvoir la consommer : (1) Vote obligatoire Art. 62 → participation élevée → légitimité formelle, (2) Listes partisanes → case de tête dévolutive → le parti choisit, (3) Discipline 99,73% → Parlement entérine, (4) Kern + sommets → présidents décident → 188,3 M€, (5) Aucun référendum Art. 33 → pas d'irruption populaire, (6) Retour à l'obligation. Le circuit est parfaitement légal ET profondément illégitime.",
      "inDefinedTermSet": {"@type": "DefinedTermSet", "name": "Concepts ouaisfieu"}
    },
    {
      "@type": "DefinedTerm",
      "name": "Trois Guerres Civiques (三种公民战法)",
      "description": "Cadre doctrinal ouaisfieu transposant la doctrine chinoise des Trois Guerres (三种战法) au combat démocratique non-violent. Guerre I (Le Récit) : OSINT citoyen, lead-dexing, contre-narratifs documentés. Guerre II (Dé-sidération) : éducation permanente, formation analyse critique, rupture de l'impuissance apprise. Guerre III (Le Prétoire) : contentieux stratégique, Art. 23 standstill, CEDS, CEDH, saturation judiciaire.",
      "inDefinedTermSet": {"@type": "DefinedTermSet", "name": "Concepts ouaisfieu"}
    }
  ]
